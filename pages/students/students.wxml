<view class="page">
  <view class="section" id="student-form">
    <view class="section-title">{{editingStudentId ? '编辑学员课程' : '新增学员课程'}}</view>
    <view class="card form-card">
      <view class="field">
        <text class="field-label">学员姓名</text>
        <input class="input" placeholder="请输入学员姓名" value="{{form.name}}" data-key="name" bindinput="onInput" />
      </view>
      <view class="field">
        <text class="field-label">家长姓名</text>
        <input class="input" placeholder="如：王妈妈" value="{{form.guardian}}" data-key="guardian" bindinput="onInput" />
      </view>
      <view class="field">
        <text class="field-label">联系电话</text>
        <input class="input" type="number" placeholder="用于后续绑定家长端" value="{{form.phone}}" data-key="phone" bindinput="onInput" />
      </view>
      <view class="field">
        <text class="field-label">报名课程</text>
        <picker range="{{courseNames}}" value="{{courseIndex}}" bindchange="onCourseChange">
          <view class="input picker-text">{{courseNames[courseIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="field-label">初始课时</text>
        <input class="input" type="digit" placeholder="如：20" value="{{form.remaining}}" data-key="remaining" bindinput="onInput" />
      </view>
      <view class="form-actions">
        <button class="primary-button" bindtap="saveStudent">{{editingStudentId ? '保存修改' : '保存学员'}}</button>
        <button wx:if="{{editingStudentId}}" class="ghost-button" bindtap="cancelEdit">取消编辑</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">学员-课程列表</view>
    <block wx:if="{{students.length}}">
      <view class="student card" wx:for="{{students}}" wx:key="id">
        <view class="student-main">
          <view>
            <view class="student-name">{{item.name}}</view>
            <view class="student-meta">{{item.courseName}} · {{item.guardian || '未填家长'}}</view>
          </view>
          <view class="student-hours">
            <view class="student-hours-value">{{item.remaining}}</view>
            <view class="student-hours-label">剩余课时</view>
          </view>
        </view>
        <view class="student-actions">
          <view class="list-button list-button-ghost" data-id="{{item.id}}" bindtap="recharge">充课时</view>
          <view class="list-button list-button-primary" data-id="{{item.id}}" bindtap="todayCheckin">当日打卡</view>
          <picker mode="date" data-id="{{item.id}}" bindchange="makeupCheckin">
            <view class="list-button list-button-ghost picker-action">补打卡</view>
          </picker>
          <view class="list-button list-button-ghost" data-id="{{item.id}}" bindtap="startEdit">编辑</view>
          <view class="list-button list-button-danger" data-id="{{item.id}}" bindtap="deleteStudent">删除</view>
        </view>
      </view>
    </block>
    <view wx:else class="card empty">暂无学员，先添加一个学员</view>
  </view>

  <view wx:if="{{rechargeDialog.visible}}" class="dialog-mask" bindtap="cancelRecharge">
    <view class="dialog card" catchtap="noop">
      <view class="dialog-title">充课时</view>
      <view class="dialog-subtitle">{{rechargeDialog.studentName}} · {{rechargeDialog.courseName}}</view>
      <view class="field">
        <text class="field-label">充值课时数</text>
        <input class="input" type="digit" focus="{{rechargeDialog.visible}}" placeholder="请输入课时数" value="{{rechargeDialog.hours}}" bindinput="onRechargeHoursInput" />
      </view>
      <view class="dialog-actions">
        <button class="dialog-button dialog-button-ghost" bindtap="cancelRecharge">取消</button>
        <button class="dialog-button dialog-button-primary" bindtap="confirmRechargeInput">确认</button>
      </view>
    </view>
  </view>
</view>
