<view class="page dashboard-page">
  <view class="hero">
    <view>
      <view class="hero-title">课时小伙伴</view>
      <view class="hero-subtitle">学员、消课、记录一处管理</view>
    </view>
    <view class="hero-badge">免费使用</view>
  </view>

  <view class="stats-grid section">
    <view class="stat card">
      <view class="stat-value">{{stats.studentCount}}</view>
      <view class="stat-label">学员课程</view>
    </view>
    <view class="stat card">
      <view class="stat-value">{{stats.totalRemaining}}</view>
      <view class="stat-label">剩余课时</view>
    </view>
  </view>

  <view wx:if="{{permissions.canManageStudents || permissions.canManageCourses}}" class="section">
    <view class="section-title">快捷操作</view>
    <view class="quick-actions">
      <button wx:if="{{permissions.canManageStudents}}" class="primary-button" bindtap="goStudents">新增学员</button>
      <button wx:if="{{permissions.canManageCourses}}" class="ghost-button" bindtap="goCourses">新增课程</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">最近记录</view>
    <view class="card recent-card">
      <block wx:if="{{recentRecords.length}}">
        <view class="record-row" wx:for="{{recentRecords}}" wx:key="id">
          <view>
            <view class="record-title">{{item.studentName}} · {{item.courseName}}</view>
            <view class="record-time">{{item.createdAt}}</view>
          </view>
          <view class="record-hours {{item.direction === 'plus' ? 'plus' : ''}}">
            {{item.direction === 'plus' ? '+' : '-'}}{{item.hours}}
          </view>
        </view>
      </block>
      <view wx:else class="empty">暂无记录</view>
    </view>
  </view>
</view>
