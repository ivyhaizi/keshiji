<view class="page dashboard-page">
  <view class="hero">
    <view>
      <view class="hero-title">课时记</view>
      <view class="hero-subtitle">教务、消课、记录一处管理</view>
    </view>
    <view class="hero-badge">免费试用</view>
  </view>

  <view class="stats-grid section">
    <view class="stat card">
      <view class="stat-value">{{stats.studentCount}}</view>
      <view class="stat-label">学员</view>
    </view>
    <view class="stat card">
      <view class="stat-value">{{stats.totalRemaining}}</view>
      <view class="stat-label">剩余课时</view>
    </view>
    <view class="stat card">
      <view class="stat-value">{{stats.monthConsumed}}</view>
      <view class="stat-label">本月消课</view>
    </view>
    <view class="stat card">
      <view class="stat-value warning">{{stats.lowBalance}}</view>
      <view class="stat-label">低余额</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">快捷操作</view>
    <view class="quick-actions">
      <button class="primary-button" bindtap="goCheckin">上课打卡</button>
      <button class="ghost-button" bindtap="goStudents">新增学员</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">最近记录</view>
    <view class="card recent-card">
      <block wx:if="{{recentRecords.length}}">
        <view class="record-row" wx:for="{{recentRecords}}" wx:key="id">
          <view>
            <view class="record-title">{{item.studentName}} · {{item.courseName}}</view>
            <view class="record-time">{{item.createdAt}}</view>
          </view>
          <view class="record-hours {{item.type === 'recharge' ? 'plus' : ''}}">
            {{item.type === 'recharge' ? '+' : '-'}}{{item.hours}}
          </view>
        </view>
      </block>
      <view wx:else class="empty">暂无上课记录</view>
    </view>
  </view>
</view>
