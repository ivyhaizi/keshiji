<view class="page">
  <view class="section">
    <view class="org-card">
      <view class="org-name">{{profile.org.name}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">当前数据</view>
    <view class="stats-card card">
      <view class="profile-stat">
        <view class="profile-stat-value">{{profile.totals.studentCount}}</view>
        <view class="profile-stat-label">学员课程</view>
      </view>
      <view class="profile-stat">
        <view class="profile-stat-value">{{profile.totals.recordCount}}</view>
        <view class="profile-stat-label">课时流水</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">关于</view>
    <view class="card info-card">
      <view class="info-row">
        <text>版本</text>
        <text class="muted">体验版</text>
      </view>
      <view class="info-row">
        <text>数据保存</text>
        <text class="muted">微信云开发</text>
      </view>
    </view>
  </view>
</view>
