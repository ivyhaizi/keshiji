.org-card {
  box-sizing: border-box;
  padding: 34rpx;
  border-radius: 18rpx;
  background: #111827;
  color: #ffffff;
}

.org-name {
  font-size: 38rpx;
  font-weight: 800;
}

.org-role {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rpx;
  overflow: hidden;
}

.profile-stat {
  padding: 28rpx;
  background: #ffffff;
}

.profile-stat-value {
  color: #1677ff;
  font-size: 42rpx;
  font-weight: 800;
}

.profile-stat-label {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.info-card {
  padding: 0 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  border-bottom: 1rpx solid #edf1f7;
  color: #111827;
  font-size: 28rpx;
}

.info-row:last-child {
  border-bottom: 0;
}

.picker-text {
  display: flex;
  align-items: center;
  color: #111827;
}

.join-card {
  padding: 24rpx;
}

.member-form {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.member-form-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.member {
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.member-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.member-name {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.member-meta,
.member-note {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.member-note {
  color: #b45309;
}

.member-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 12rpx;
  margin-top: 18rpx;
}

.list-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 132rpx;
  min-width: 0;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
}

.list-button-ghost {
  border: 1rpx solid #cbd5e1;
  background: #ffffff;
  color: #1f2937;
}

.list-button-danger {
  background: #fff1f2;
  color: #e11d48;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 36rpx;
  background: rgba(15, 23, 42, 0.42);
}

.dialog {
  width: 620rpx;
  max-width: 100%;
  padding: 28rpx;
}

.dialog-title {
  margin-bottom: 24rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 220rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #d7deea;
  border-radius: 14rpx;
  background: #ffffff;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.5;
}

.dialog-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.dialog-button {
  box-sizing: border-box;
  width: 148rpx;
  min-width: 0;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.dialog-button::after {
  border: 0;
}

.dialog-button-ghost {
  border: 1rpx solid #cbd5e1;
  background: #ffffff;
  color: #1f2937;
}

.dialog-button-primary {
  background: #1677ff;
  color: #ffffff;
}
