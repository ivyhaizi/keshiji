.org-card {
  box-sizing: border-box;
  padding: 34rpx;
  border-radius: 18rpx;
  background: #111827;
  color: #ffffff;
}

.org-name {
  font-size: 38rpx;
  font-weight: 800;
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rpx;
  overflow: hidden;
}

.profile-stat {
  padding: 28rpx;
  background: #ffffff;
}

.profile-stat-value {
  color: #1677ff;
  font-size: 42rpx;
  font-weight: 800;
}

.profile-stat-label {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.info-card {
  padding: 0 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  border-bottom: 1rpx solid #edf1f7;
  color: #111827;
  font-size: 28rpx;
}

.info-row:last-child {
  border-bottom: 0;
}
