page {
  min-height: 100%;
  background: #f6f8fb;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 0 18rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.card {
  box-sizing: border-box;
  border: 1rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(31, 41, 55, 0.05);
}

.muted {
  color: #667085;
}

.primary-button,
.ghost-button,
.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 84rpx;
}

.primary-button {
  background: #1677ff;
  color: #ffffff;
}

.ghost-button {
  border: 1rpx solid #cbd5e1;
  background: #ffffff;
  color: #1f2937;
}

.danger-button {
  background: #fff1f2;
  color: #e11d48;
}

.field {
  margin-bottom: 20rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #344054;
  font-size: 26rpx;
  font-weight: 600;
}

.input {
  box-sizing: border-box;
  width: 100%;
  min-height: 82rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d7deea;
  border-radius: 14rpx;
  background: #ffffff;
  color: #111827;
  font-size: 28rpx;
}

.empty {
  padding: 44rpx 24rpx;
  color: #667085;
  text-align: center;
}
